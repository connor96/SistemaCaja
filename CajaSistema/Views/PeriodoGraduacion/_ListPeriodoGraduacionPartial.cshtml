@model IEnumerable<PeriodoGraduacion>

@{
    Layout = null;
    int contador = 1;
}

@if (Model == null || !Model.Any())
{
    <h5>No se encontraron periodos activos</h5>
}
else
{
    <table class="table table-hover" id="tablaPeriodos">
        <thead>
            <tr>
                <th scope="col">#</th>
                <th scope="col">Descripcion</th>
                <th scope="col">F. Registro</th>
                <th scope="col">Estado</th>
                <th scope="col">Editar</th>
                <th scope="col">Eliminar</th>
            </tr>
        </thead>
        <tbody id="cuerpo_tabla">

        @foreach (var item in Model)
        {
            <tr class="item-tr-@contador">
                <td scope="row">@contador</td>
                <td id="label-@contador">@item.periodoDescripcion</td>
                <td id="label-@contador">@item.fechaRegistro.ToString("dd/MM/yyyy")</td>

                <td id="label-@contador">

                    @if (item.estado == true)
                    {
                        <p style="color:blue"> Activo</p>
                    }
                    else
                    {
                        <p style="color:red"> Inactivo</p>
                    }

                </td>

                <td> <a class="btn btn-outline-secondary" onclick="editarPeriodo('@item.idPeriodoGraduacion')">Editar</a> </td>
                <td> <a class="btn btn-outline-danger" onclick="eliminarPeriodo('@item.idPeriodoGraduacion')">Eliminar</a> </td>

            </tr>
            contador++;
        }
        </tbody>
    </table>

}
