
@{
    ViewData["Title"] = "Periodo Graduacion";
    
}

<div class="row container">

    <!-- Button trigger modal -->

    <div class="row" style="padding-top:2em;padding-bottom:2em">
        <div class="col-8">
            <h4>Lista de Periodos de Graduacion</h4>
        </div>

        <div class="col-4 d-flex justify-content-end">
            @* <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#exampleModal">
                Agregar Periodo
            </button> *@

            <button type="button" class="btn btn-primary" onclick="nuevoPeriodo()">
                Agregar Periodo
            </button>

        </div>

    </div>

    <!-- Lista Perido -->

    <div id="tablaListaPeriodo" class="tablaListaPeriodo">

    </div>

</div>

<div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
   @*  @await Html.PartialAsync("_ModalRegistrarPeriodoGraduacion")  *@
</div>

@section Scripts {
    <script>

        $(document).ready(function () {
            cargarLista();
        });

        function cargarLista() {
            $("#tablaListaPeriodo").load('@Url.Action("_ListPeriodoGraduacionPartial", "PeriodoGraduacion")');
        }

        function editarPeriodo(id) {
            var url='@Url.Action("_ModalEditarPeriodoGraduacion", "PeriodoGraduacion")';

            $("#exampleModal").load(url + '?id=' + id, function () {
                $("#exampleModal").modal('show');
            });
        }

        function nuevoPeriodo() {
            $("#exampleModal").load('@Url.Action("_ModalRegistrarPeriodoGraduacion", "PeriodoGraduacion")', function () {
                $("#exampleModal").modal('show');
            });
        }

        function eliminarPeriodo(id){

            Swal.fire({
              title: "Esta seguro de eliminar?",
              text: "Esta seguro de eliminar el periodo",
              icon: "warning",
              showCancelButton: true,
              confirmButtonColor: "#3085d6",
              cancelButtonColor: "#d33",
              confirmButtonText: "Eliminar"
            }).then((result) => {
              if (result.isConfirmed) {
                    var url='@Url.Action("EliminarPeriodoGraduacion", "PeriodoGraduacion")';
                    $.ajax({
                        url: url,
                        type: "POST",
                        data: {id:id},
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                title: "Exito!",
                                icon: "success",
                                text:response.message,
                                }).then((result)=>{
                                    // Recargar partial
                                    cargarLista();
                                });

                            } else {
                                alert(response.message);
                            }
                        },
                        error: function () {
                            alert("Error al registrar");
                        }
                    });
                }
              
            });


            


        }

        $(document).on("submit", "#formPeriodoGraduacion", function (e) {
            e.preventDefault();

            $.ajax({
                url: $(this).attr("action"),
                type: "POST",
                data: $(this).serialize(),
                success: function (response) {

                    if (response.success) {

                        Swal.fire({
                        title: "Exito!",
                        icon: "success",
                        text:response.message,
                        }).then((result)=>{
                             $("#exampleModal").modal("hide");

                            // Recargar partial
                            cargarLista();

                        });
                        //alert(response.message);

                        // Cerrar modal
                       
                    } else {
                        alert(response.message);
                    }
                },
                error: function () {
                    alert("Error al registrar");
                }
            });
        });

        $(document).on("submit", "#formUpdatePeriodoGraduacion", function (e) {
            e.preventDefault();

            $.ajax({
                url: $(this).attr("action"),
                type: "POST",
                data: $(this).serialize(),
                success: function (response) {

                    if (response.success) {

                        Swal.fire({
                        title: "Exito!",
                        icon: "success",
                        text:response.message,
                        }).then((result)=>{
                             $("#exampleModal").modal("hide");

                            // Recargar partial
                            cargarLista();

                        });
                    } else {
                        alert(response.message);
                    }
                },
                error: function () {
                    alert("Error al registrar");
                }
            });
        });

    </script>



}




