
@model PeriodoGraduacion

<div class="modal-dialog">
    <div class="modal-content">

        <form id="formPeriodoGraduacion" asp-action="CrearPeriodoGraduacion" method="post">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h5 class="modal-title" id="exampleModalLabel">Registro nuevo periodo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="container modal-body">

                <div class="mb-3">
                    <label class="form-label">Descripción</label>
                    <input asp-for="periodoDescripcion" class="form-control" />
                    <span asp-validation-for="periodoDescripcion" class="text-danger"></span>
                </div>

            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="submit" class="btn btn-primary">
                    Registrar
                </button>
            </div>


        </form>


        
    </div>
</div>
